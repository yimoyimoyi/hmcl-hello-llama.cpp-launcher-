{
    "_FILE_COMMENT_0": "═" ,
    "_FILE_COMMENT_1": "ui_config.json — Llama.cpp 启动器 用户界面配置文件",
    "_FILE_COMMENT_2": "修改本文件可直接定制启动器的显示文字和界面行为，无需修改 Python 代码。",
    "_FILE_COMMENT_3": "修改后重启启动器即可生效。",
    "_FILE_COMMENT_4": "注意：JSON 标准不支持注释，因此用 _ 前缀的键模拟注释。",
    "_FILE_COMMENT_5": "可安全修改所有 value（text/tooltip/label/color 等），不要删除或重命名键。",
    "_FILE_COMMENT_6": "可用占位符 {name} {path} {error} {code} {count} {mode} {ngl} {free} {total} {err}",
    "_FILE_COMMENT_7": "═" ,

    "参数定义": {
        "_comment": "schema 数组定义动态生成的参数控件。每个 group 对应一个 QGroupBox 分组。",
        "schema": [
            {
                "group_name": " 推理核心参数 (自动生成) ",
                "_comment": "第一组：模型推理的核心超参数。",
                "params": [
                    {"id": "ngl",            "label": "GPU 层数 (-ngl):",       "type": "string", "default": "auto",   "arg": "-ngl",            "width": 12, "tooltip": "GPU 卸载层数：auto=自动检测, all=全部, 或指定数字"},
                    {"id": "ctx",            "label": "上下文 (-c):",           "type": "int",    "default": 8192,     "arg": "-c",              "min": 512,   "max": 131072, "step": 512,  "width": 12, "tooltip": "上下文窗口大小（token 数），0=从模型读取"},
                    {"id": "temp",           "label": "温度 (--temp):",         "type": "float",  "default": 0.7,       "arg": "--temp",          "min": 0.0,   "max": 2.0,   "step": 0.05, "width": 10, "tooltip": "生成温度，越高越随机，默认 0.80"},
                    {"id": "rep_pen",        "label": "重复惩罚 (-rp):",        "type": "float",  "default": 1.1,       "arg": "--repeat-penalty", "min": 0.5,   "max": 2.0,   "step": 0.05, "width": 10, "tooltip": "重复惩罚系数，1.0=禁用"},
                    {"id": "threads",        "label": "CPU 线程 (-t):",         "type": "int",    "default": 8,         "arg": "-t",              "min": 1,     "max": 64,    "step": 1,    "width": 12, "tooltip": "CPU 并行线程数，默认 -1=自动"},
                    {"id": "tb",             "label": "批线程 (-tb):",          "type": "int",    "default": 1,         "arg": "-tb",             "min": 1,     "max": 64,    "step": 1,    "width": 12, "tooltip": "批处理线程数，默认同 --threads"},
                    {"id": "batch",          "label": "批大小 (-b):",           "type": "int",    "default": 512,       "arg": "-b",              "min": 1,     "max": 32768, "step": 128,  "width": 12, "tooltip": "逻辑最大批大小，默认 2048"},
                    {"id": "ubatch",         "label": "物理批 (-ub):",          "type": "int",    "default": 512,       "arg": "-ub",             "min": 1,     "max": 32768, "step": 128,  "width": 12, "tooltip": "物理最大批大小，默认 512"},
                    {"id": "min_p",          "label": "最低概率 (--min-p):",    "type": "float",  "default": 0.05,      "arg": "--min-p",         "min": 0.0,   "max": 1.0,   "step": 0.01, "width": 12, "tooltip": "min-p 采样，0.0=禁用"},
                    {"id": "top_p",          "label": "最高概率 (--top-p):",    "type": "float",  "default": 0.95,      "arg": "--top-p",         "min": 0.0,   "max": 1.0,   "step": 0.01, "width": 12, "tooltip": "top-p 核采样，1.0=禁用"},
                    {"id": "image_min_tokens","label": "图像最小 Token:",        "type": "string", "default": "",        "arg": "--image-min-tokens","width": 12, "tooltip": "多模态每张图像最小 token 数"},
                    {"id": "image_max_tokens","label": "图像最大 Token:",        "type": "string", "default": "",        "arg": "--image-max-tokens","width": 12, "tooltip": "多模态每张图像最大 token 数"}
                ]
            },
            {
                "group_name": " 显存与去重优化 ",
                "_comment": "第二组：KV Cache 压缩、DRY 去重、显存优化选项。",
                "params": [
                    {"id": "cache_k",    "label": "Cache K 类型:",       "type": "string", "default": "q8_0", "arg": "--cache-type-k",    "width": 12, "tooltip": "K Cache 数据类型: f32/f16/bf16/q8_0/q4_0 等，默认 f16"},
                    {"id": "cache_v",    "label": "Cache V 类型:",       "type": "string", "default": "q8_0", "arg": "--cache-type-v",    "width": 12, "tooltip": "V Cache 数据类型: f32/f16/bf16/q8_0/q4_0 等，默认 f16"},
                    {"id": "dry_mult",   "label": "DRY 乘数:",           "type": "float",  "default": 0.8,   "arg": "--dry-multiplier", "min": 0.0,   "max": 5.0,   "step": 0.1,  "width": 12, "tooltip": "DRY 采样乘数，0.0=禁用"},
                    {"id": "dry_base",   "label": "DRY 基础:",           "type": "float",  "default": 1.75,  "arg": "--dry-base",       "min": 0.0,   "max": 10.0,  "step": 0.05, "width": 12, "tooltip": "DRY 采样基础值，默认 1.75"},
                    {"id": "dry_len",    "label": "DRY 允许长度:",       "type": "int",    "default": 2,     "arg": "--dry-allowed-length","min": 0,   "max": 100,   "step": 1,    "width": 12, "tooltip": "DRY 允许的最大重复 token 长度，默认 2"},
                    {"id": "flash_attn", "label": "Flash-Attn:",         "type": "bool",   "default": true,  "arg": "--flash-attn",     "bool_val": "on", "tooltip": "启用 Flash Attention，显著节省显存"},
                    {"id": "no_mmap",    "label": "禁用 MMAP:",          "type": "bool",   "default": false, "arg": "--no-mmap",        "bool_val": "", "tooltip": "禁用内存映射加载（更慢但可能减少 pageout）"},
                    {"id": "mlock",      "label": "锁定内存:",           "type": "bool",   "default": false, "arg": "--mlock",          "bool_val": "", "tooltip": "强制模型常驻物理 RAM，防止被 swap"},
                    {"id": "cmoe",       "label": "专家常驻 (-cmoe):",   "type": "bool",   "default": false, "arg": "-cmoe",           "bool_val": "", "tooltip": "MoE 所有专家权重保留在 GPU"},
                    {"id": "ncmoe",      "label": "内存专家层数:",       "type": "string", "default": "",     "arg": "-ncmoe",          "width": 12, "tooltip": "前 N 层 MoE 专家权重保留在 CPU"}
                ]
            }
        ]
    },

    "按钮文字与提示": {
        "_comment": "按钮显示文字和 tooltip。theme 按钮有两个文字：text_dark（暗色模式）/ text_light（亮色模式）。",
        "buttons": {
            "launch":        {"text": "▶ 启动",        "tooltip": "启动当前配置的模型"},
            "stop":          {"text": "⏹ 停止",        "tooltip": "停止运行中的进程"},
            "preview":       {"text": "📋 预览",        "tooltip": "预览即将执行的命令"},
            "theme":         {"text_dark": "🌙 暗色",  "text_light": "☀ 亮色", "tooltip": "切换亮色/暗色主题"},
            "refresh":       {"text": "🔄 刷新模型",    "tooltip": ""},
            "save_preset":   {"text": "💾 保存状态",    "tooltip": ""},
            "delete_preset": {"text": "🗑 删除预设",    "tooltip": "删除当前选中模型的已保存预设"},
            "download_bin":  {"text": "⬇ 下载 Bin",    "tooltip": "下载 llama.cpp 二进制文件"},
            "update_bin":    {"text": "🔄 更新 Bin",    "tooltip": "下载前清空 bin 目录 (仅 Windows)"},
            "stop_download": {"text": "⏹ 停止下载",    "tooltip": "中断正在进行的下载"},
            "vram_detect":   {"text": "🎯 显存检测",    "tooltip": "检测空闲显存并自动设置 GPU 层数"},
            "browse":        {"text": "浏览",           "tooltip": ""},
            "open_dir":      {"text": "打开",           "tooltip": ""},
            "redetect":      {"text": "重新检测",        "tooltip": ""},
            "select_mmproj": {"text": "选择",           "tooltip": ""},
            "copy":          {"text": "📋 复制",        "tooltip": "复制命令到剪贴板"},
            "gen_bat":       {"text": "📝 生成 Bat",    "tooltip": "生成 .bat 启动脚本到程序目录"},
            "close":         {"text": "关闭",           "tooltip": ""},
            "send":          {"text": "发送",           "tooltip": ""},
            "clear":         {"text": "清屏",           "tooltip": ""},
            "export_log":    {"text": "📥 导出日志",    "tooltip": "将控制台内容导出为日志文件"}
        }
    },

